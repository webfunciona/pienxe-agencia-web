---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '~/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---
<section id={t('anchor.colaboracion')} class="scope" data-screen-label={`06 ${t('nav.pricing')}`}>
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow reveal"><span class="num">§ 06</span> · {t('nav.pricing')}</div>
        <h2 class="section-title reveal" data-delay="1" set:html={t('pricing.title')} />
      </div>
      <p class="section-sub reveal" data-delay="2">{t('pricing.subtitle')}</p>
    </div>

    <div class="pricing">
      <article class="plan reveal">
        <div class="plan-badge">{t('pricing.modelA.badge')}</div>
        <h3 class="plan-name" set:html={t('pricing.modelA.title')} />
        <p class="plan-desc">{t('pricing.modelA.desc')}</p>
        <ul>
          {t('pricing.modelA.items').split('|').map((item) => (
            <li>
              <svg class="check" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a class="cta-secondary" href={translatePath('contact')}>{t('pricing.modelA.cta')} <span aria-hidden="true">→</span></a>
      </article>

      <article class="plan rec reveal" data-delay="1">
        <div class="plan-rec-tag">
          <svg class="iso" viewBox="0 0 584 584" fill="none" aria-hidden="true"><path d="M289.904 42C297.263 50.2552 296.991 190.772 333.37 236.563C341.654 246.99 352.397 254.688 364.376 260.284C410.836 281.987 493.918 286.452 545 292.024C489.146 301.954 396.439 298.906 347.999 333.213C298.617 368.186 300.234 483.697 291.334 540.689L291.211 542C288.688 541.523 287.503 522.308 287.137 518.904C282.144 472.436 277.079 391.024 250.715 352.066C213.35 296.857 100.063 302.886 41.7987 292.348L40 292.014C263.201 266.211 267.634 272.765 289.904 42Z" fill="#02DEF0"/></svg>
          {t('pricing.modelB.recommendation')}
        </div>
        <div class="plan-badge">{t('pricing.modelB.badge')}</div>
        <h3 class="plan-name" set:html={t('pricing.modelB.title')} />
        <p class="plan-desc">{t('pricing.modelB.desc')}</p>
        <ul>
          {t('pricing.modelB.items').split('|').map((item) => (
            <li>
              <svg class="check" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a class="cta-primary" href={translatePath('contact')}>{t('pricing.modelB.cta')} <span aria-hidden="true">→</span></a>
      </article>
    </div>
  </div>
</section>